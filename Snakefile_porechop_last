rule all:
    input:
        "nanoq_output.txt",
        "seqtk_output.fq"

rule nanoq:
    output:
        "nanoq_output.txt"
    shell:
        "nanoq -i input.fq -o {output}"

rule seqtk:
    output:
        "seqtk_output.fq"
    shell:
        "seqtk sample input.fq 1000 > {output}"

rule porechop:
    input:
        "seqtk_output.fq"
    output:
        "porechop_output.fq"
    shell:
        "porechop -i {input} -o {output}"